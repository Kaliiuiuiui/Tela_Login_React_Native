import React, { useState } from 'react';
import { View, Text, TextInput, StyleSheet, TouchableOpacity, ScrollView } from 'react-native';

function Botao({ titulo, onPress, cor = "#4CAF50" }) {
  return (
    <TouchableOpacity onPress={onPress} style={[styles.botao, { backgroundColor: cor }]}>
      <Text style={styles.textoBotao}>{titulo}</Text>
    </TouchableOpacity>
  );
}

export default function App() {

  const [login, setLogin] = useState('');
  const [senha, setSenha] = useState('');
  const [mensagem, setMensagem] = useState('');
  const [tela, setTela] = useState('');
  const [mostrarSenha, setMostrarSenha] = useState(false);

  const [alunos, setAlunos] = useState([]);
  const [nome, setNome] = useState('');
  const [idade, setIdade] = useState('');
  const [curso, setCurso] = useState('');

  const [indiceEdicao, setIndiceEdicao] = useState(null);

  function validarLogin() {
    setMensagem('');

    if (login === 'admin' && senha === '123') {
      setTela('mudar');
    } else {
      setMensagem('Login ou senha incorretos!');
    }
  }

  function cadastrarAluno() {
    if (nome.trim() === '' || idade.trim() === '' || curso.trim() === '') {
      setMensagem('Preencha todos os campos!');
      return;
    }

    const novoAluno = { nome, idade, curso };
    setAlunos([...alunos, novoAluno]);

    setNome('');
    setIdade('');
    setCurso('');
    setMensagem('');
  }

  function voltarTela() {
    setTela('');
    setLogin('');
    setSenha('');
    setMensagem('');
  }

  function atualizarAluno() {
    const novaLista = [...alunos];
    novaLista[indiceEdicao] = { nome, idade, curso };
    setAlunos(novaLista);

    setIndiceEdicao(null);
    setNome('');
    setIdade('');
    setCurso('');
  }

  function editarAluno(index) {
    const aluno = alunos[index];
    setNome(aluno.nome);
    setIdade(aluno.idade);
    setCurso(aluno.curso);
    setIndiceEdicao(index);
  }

  function removerAluno(index) {
    const novaLista = alunos.filter((_, i) => i !== index);
    setAlunos(novaLista);
    setIndiceEdicao(null);
  }

  if (tela === 'mudar') {
    return (
      <View style={styles.container}>
        <Text style={styles.titulo}>Cadastro de Alunos</Text>

        <Text style={styles.texto}>Nome:</Text>
        <TextInput style={styles.input} placeholder="Digite o nome" onChangeText={setNome} value={nome} />

        <Text style={styles.texto}>Idade:</Text>
        <TextInput style={styles.input} placeholder="Digite a idade" onChangeText={setIdade} value={idade} keyboardType="numeric" />

        <Text style={styles.texto}>Curso:</Text>
        <TextInput style={styles.input} placeholder="Digite o curso" onChangeText={setCurso} value={curso} />

        {
          indiceEdicao === null ? (
            <Botao titulo="Cadastrar aluno" onPress={cadastrarAluno} />
          ) : (
            <Botao titulo="Salvar edição" onPress={atualizarAluno} cor="#2196F3" />
          )
        }

        <ScrollView style={{ marginTop: 10 }}>
          {alunos.map((aluno, index) => (
            <View key={index}>
              <Text style={styles.texto}>Nome: {aluno.nome}</Text>
              <Text style={styles.texto}>Idade: {aluno.idade}</Text>
              <Text style={styles.texto}>Curso: {aluno.curso}</Text>

              <Botao titulo="Editar" onPress={() => editarAluno(index)} cor="#FFC107" />
              <Botao titulo="Excluir" onPress={() => removerAluno(index)} cor="#F44336" />

              <Text style={styles.texto}>--------------------</Text>
            </View>
          ))}
        </ScrollView>

        <Botao titulo="Voltar" onPress={voltarTela} cor="#9E9E9E" />

        <Text style={{ color: 'white', marginTop: 10 }}>{mensagem}</Text>
      </View>
    );
  }

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}>Tela de Login</Text>

      <Text style={styles.texto}>Login:</Text>
      <TextInput style={styles.input} placeholder="Digite seu nome" onChangeText={setLogin} value={login} />

      <Text style={styles.texto}>Senha:</Text>
      <TextInput
        style={styles.input}
        placeholder="Digite sua senha"
        onChangeText={setSenha}
        value={senha}
        secureTextEntry={!mostrarSenha}
      />

      <TouchableOpacity onPress={() => setMostrarSenha(!mostrarSenha)}>
        <Text style={{ color: 'white', marginBottom: 10 }}>
          {mostrarSenha ? 'Ocultar senha' : 'Mostrar senha'}
        </Text>
      </TouchableOpacity>

      <Botao titulo="Entrar" onPress={validarLogin} />

      <Text style={{ color: 'white', marginTop: 10 }}>{mensagem}</Text>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    alignItems: "center",
    backgroundColor: "#383838",
    flex: 1,
    justifyContent: "center",
  },

  titulo: {
    fontSize: 25,
    color: "#ffffff",
    margin: 15,
  },

  texto: {
    color: "#ffffff"
  },

  input: {
    textAlign: "center",
    borderWidth: 1,
    borderRadius: 8,
    color: "grey",
    backgroundColor: "#ffffff",
    marginBottom: 15,
    padding: 5,
    width: 200
  },

  botao: {
    paddingVertical: 10,
    paddingHorizontal: 20,
    borderRadius: 8,
    marginVertical: 5,
    alignItems: "center",
    width: 200,
  },

  textoBotao: {
    color: "#fff",
    fontWeight: "bold",
    fontSize: 16,
  }
});
